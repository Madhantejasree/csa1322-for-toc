#include <stdio.h>
#include <string.h>

int main() {
    char str[50];
    int i, valid = 1;

    printf("Enter string: ");
    scanf("%s", str);

    int n = strlen(str);

    if(str[0] == '0' && str[n-1] == '1') {
        for(i = 1; i < n-1; i++) {
            if(str[i] != '0' && str[i] != '1') {
                valid = 0;
                break;
            }
        }
    } else {
        valid = 0;
    }

    if(valid)
        printf("String belongs to the language\n");
    else
        printf("String does not belong to the language\n");

    return 0;
}
